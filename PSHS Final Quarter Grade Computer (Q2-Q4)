SA1 = float(input("Enter the grade PERCENTAGE of your summative assessment 1: "))
print(f"Summative Assessment 1 Grade Percentage is {SA1}")

SA2 = float(input("Enter the grade PERCENTAGE of your summative assessment 2: "))
print(f"Summative Assessment 2 Grade Percentage is {SA2}")

QE = float(input("Enter the grade PERCENTAGE of your quarter exam: "))
print(f"Quarter Exam Grade Percentage is {QE}")

count = int(input("Enter the number of FAs you had: "))
fa_list = []
for i in range(count):
        val = float(input("Enter the grade PERCENTAGE of your FA: "))
        fa_list.append(val)
if count > 0:
    FA_average = int(sum(fa_list) / len(fa_list))
    print(f"The average of your FAs is: {FA_average} over 100%")
else:
    print("No grades were entered.")

tentative_grade = (SA1 + SA2)*.55 / 2 + FA_average*.30 + QE*.15
print(f"Your tentative grade is: {tentative_grade} out of 100%")

last_quarter_grade = float(input("Please enter the PERCENTAGE of your final grade last quarter: "))
final_grade = (last_quarter_grade + (2 * tentative_grade)) / 3
print(f"Your Final Grade is {final_grade} out of 100%")

